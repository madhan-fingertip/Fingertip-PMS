<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Top-level category -->
        <record id="module_category_general" model="ir.module.category">
            <field name="name">General</field>
            <field name="description">Asset, Expense and Recruitment Management</field>
            <field name="sequence">20</field>
        </record>

        <!-- Asset groups -->
        <record id="group_asset_user" model="res.groups">
            <field name="name">Asset User</field>
            <field name="category_id" ref="module_category_general"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_general"/>
            <field name="implied_ids" eval="[(4, ref('group_asset_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Expense groups -->
        <record id="group_expense_user" model="res.groups">
            <field name="name">Expense User</field>
            <field name="category_id" ref="module_category_general"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_expense_manager" model="res.groups">
            <field name="name">Expense Manager</field>
            <field name="category_id" ref="module_category_general"/>
            <field name="implied_ids" eval="[(4, ref('group_expense_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Recruitment groups -->
        <record id="group_recruitment_user" model="res.groups">
            <field name="name">Recruitment User</field>
            <field name="category_id" ref="module_category_general"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_recruitment_manager" model="res.groups">
            <field name="name">Recruitment Manager</field>
            <field name="category_id" ref="module_category_general"/>
            <field name="implied_ids" eval="[(4, ref('group_recruitment_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Multi-company rules -->
        <record id="company_asset_company_rule" model="ir.rule">
            <field name="name">Company Asset: multi-company</field>
            <field name="model_id" ref="model_company_asset"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="employee_expense_claim_company_rule" model="ir.rule">
            <field name="name">Expense Claim: multi-company</field>
            <field name="model_id" ref="model_employee_expense_claim"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="recruitment_candidate_company_rule" model="ir.rule">
            <field name="name">Recruitment Candidate: multi-company</field>
            <field name="model_id" ref="model_recruitment_candidate"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

       <!-- Record rule: regular users see only claims belonging to them -->
        <record id="employee_expense_claim_own_rule" model="ir.rule">
            <field name="name">Expense Claim: own claims only</field>
            <field name="model_id" ref="model_employee_expense_claim"/>
            <field name="domain_force">
                ['|',
                    ('employee.user_id', '=', user.id),
                    ('create_uid', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('group_expense_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record rule: managers see ALL claims -->
        <record id="employee_expense_claim_manager_rule" model="ir.rule">
            <field name="name">Expense Claim: managers see all</field>
            <field name="model_id" ref="model_employee_expense_claim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_expense_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================
             ASSET MANAGEMENT — record rules
             User: own records only.  Manager: all records.
             ============================================================ -->

        <!-- company.asset — users see only their own -->
        <record id="company_asset_user_rule" model="ir.rule">
            <field name="name">Asset: own records only</field>
            <field name="model_id" ref="model_company_asset"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_asset_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- company.asset — managers see all -->
        <record id="company_asset_manager_rule" model="ir.rule">
            <field name="name">Asset: managers see all</field>
            <field name="model_id" ref="model_company_asset"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_asset_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- asset.assignment — users see only their own -->
        <record id="asset_assignment_user_rule" model="ir.rule">
            <field name="name">Asset Assignment: own records only</field>
            <field name="model_id" ref="model_asset_assignment"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_asset_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- asset.assignment — managers see all -->
        <record id="asset_assignment_manager_rule" model="ir.rule">
            <field name="name">Asset Assignment: managers see all</field>
            <field name="model_id" ref="model_asset_assignment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_asset_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- asset.maintenance — users see only their own -->
        <record id="asset_maintenance_user_rule" model="ir.rule">
            <field name="name">Asset Maintenance: own records only</field>
            <field name="model_id" ref="model_asset_maintenance"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_asset_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- asset.maintenance — managers see all -->
        <record id="asset_maintenance_manager_rule" model="ir.rule">
            <field name="name">Asset Maintenance: managers see all</field>
            <field name="model_id" ref="model_asset_maintenance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_asset_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
