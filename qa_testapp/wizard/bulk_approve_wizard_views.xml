<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard form -->
    <record id="view_qa_bulk_approve_wizard_form" model="ir.ui.view">
        <field name="name">qa_testapp.bulk_approve_wizard.form</field>
        <field name="model">qa_testapp.bulk_approve_wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Approve / Reject">
                <group>
                    <field name="action_type"/>
                    <field name="target_model" invisible="1"/>
                    <field name="record_ids" invisible="1"/>
                    <field name="eligible_count"/>
                    <field name="skipped_count"/>
                    <field name="rejection_reason"
                           invisible="action_type != 'reject'"
                           required="action_type == 'reject'"/>
                </group>
                <div class="alert alert-info" role="alert" invisible="skipped_count == 0">
                    Some selected records were skipped because you are not the PM of their project.
                </div>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server action: Bulk Approve / Reject bugs (visible in list view of bug) -->
    <record id="action_qa_bug_bulk_approve" model="ir.actions.server">
        <field name="name">Approve / Reject Selected</field>
        <field name="model_id" ref="qa_testapp.model_qa_testapp_ticket"/>
        <field name="binding_model_id" ref="qa_testapp.model_qa_testapp_ticket"/>
        <field name="binding_view_types">list</field>
        <field name="groups_id" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Bulk Approve / Reject',
    'res_model': 'qa_testapp.bulk_approve_wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': dict(env.context, active_model='qa_testapp.ticket', active_ids=records.ids),
}
        </field>
    </record>

    <!-- Server action: Bulk Approve / Reject test cases -->
    <record id="action_qa_test_case_bulk_approve" model="ir.actions.server">
        <field name="name">Approve / Reject Selected</field>
        <field name="model_id" ref="qa_testapp.model_qa_testapp_test_case"/>
        <field name="binding_model_id" ref="qa_testapp.model_qa_testapp_test_case"/>
        <field name="binding_view_types">list</field>
        <field name="groups_id" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Bulk Approve / Reject',
    'res_model': 'qa_testapp.bulk_approve_wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': dict(env.context, active_model='qa_testapp.test_case', active_ids=records.ids),
}
        </field>
    </record>

</odoo>
