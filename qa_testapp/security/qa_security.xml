<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module category -->
        <record id="module_category_qa_testapp" model="ir.module.category">
            <field name="name">QA TestApp</field>
            <field name="sequence">25</field>
        </record>

        <!-- Junior QA / User group -->
        <record id="group_qa_junior" model="res.groups">
            <field name="name">Junior QA / User</field>
            <field name="category_id" ref="module_category_qa_testapp"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Junior QA users. Bugs and test cases they create require PM approval before work can start.</field>
        </record>

        <!-- Senior QA group -->
        <record id="group_qa_senior" model="res.groups">
            <field name="name">Senior QA</field>
            <field name="category_id" ref="module_category_qa_testapp"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Senior QA users. Bugs and test cases they create do NOT need approval - they are created in an editable-by-creator (read-only for others) state. Only the creator can edit; others are read-only.</field>
        </record>

        <!-- Record rule: Junior QA sees only their own bugs -->
        <record id="rule_qa_ticket_junior_own" model="ir.rule">
            <field name="name">QA Ticket: Junior QA - own records only</field>
            <field name="model_id" ref="model_qa_testapp_ticket"/>
            <field name="domain_force">['|', ('reporter_id', '=', user.id), ('assignee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_qa_junior'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record rule: Senior QA sees their own / assigned bugs -->
        <record id="rule_qa_ticket_senior_own" model="ir.rule">
            <field name="name">QA Ticket: Senior QA - own records only</field>
            <field name="model_id" ref="model_qa_testapp_ticket"/>
            <field name="domain_force">['|', ('reporter_id', '=', user.id), ('assignee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_qa_senior'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record rule: PM sees only bugs in their projects -->
        <record id="rule_qa_ticket_pm_own_projects" model="ir.rule">
            <field name="name">QA Ticket: PM - own projects only</field>
            <field name="model_id" ref="model_qa_testapp_ticket"/>
            <field name="domain_force">[('project_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record rule: Junior QA sees only their own test cases -->
        <record id="rule_qa_test_case_junior_own" model="ir.rule">
            <field name="name">QA Test Case: Junior QA - own records only</field>
            <field name="model_id" ref="model_qa_testapp_test_case"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_qa_junior'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record rule: Senior QA sees only their own test cases -->
        <record id="rule_qa_test_case_senior_own" model="ir.rule">
            <field name="name">QA Test Case: Senior QA - own records only</field>
            <field name="model_id" ref="model_qa_testapp_test_case"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_qa_senior'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record rule: PM sees only test cases in their projects -->
        <record id="rule_qa_test_case_pm_own_projects" model="ir.rule">
            <field name="name">QA Test Case: PM - own projects only</field>
            <field name="model_id" ref="model_qa_testapp_test_case"/>
            <field name="domain_force">[('project_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
