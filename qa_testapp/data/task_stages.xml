<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Project Task Stages: Planned / Working / Testing / Completed -->
    <record id="task_stage_planned" model="project.task.type">
        <field name="name">Planned</field>
        <field name="sequence">10</field>
        <field name="fold" eval="False"/>
    </record>
    <record id="task_stage_working" model="project.task.type">
        <field name="name">Working</field>
        <field name="sequence">20</field>
        <field name="fold" eval="False"/>
    </record>
    <record id="task_stage_testing" model="project.task.type">
        <field name="name">Testing</field>
        <field name="sequence">30</field>
        <field name="fold" eval="False"/>
    </record>
    <record id="task_stage_completed" model="project.task.type">
        <field name="name">Completed</field>
        <field name="sequence">40</field>
        <field name="fold" eval="True"/>
    </record>
</odoo>
