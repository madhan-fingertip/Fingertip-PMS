<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Bulk Approve: Test Cases (shown in list-view Action menu) -->
        <record id="action_bulk_approve_test_case" model="ir.actions.server">
            <field name="name">Approve Selected</field>
            <field name="model_id" ref="model_qa_testapp_test_case"/>
            <field name="binding_model_id" ref="model_qa_testapp_test_case"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
if records:
    records.action_bulk_approve()
            </field>
        </record>

        <!-- Bulk Approve: Bug Tickets -->
        <record id="action_bulk_approve_ticket" model="ir.actions.server">
            <field name="name">Approve Selected</field>
            <field name="model_id" ref="model_qa_testapp_ticket"/>
            <field name="binding_model_id" ref="model_qa_testapp_ticket"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
if records:
    records.action_bulk_approve()
            </field>
        </record>
    </data>
</odoo>
