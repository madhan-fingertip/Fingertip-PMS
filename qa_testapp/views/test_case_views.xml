<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="qa_testapp_view_test_case_list" model="ir.ui.view">
        <field name="name">qa_testapp.test_case.list</field>
        <field name="model">qa_testapp.test_case</field>
        <field name="arch" type="xml">
            <list string="Test Cases"
                  decoration-warning="approval_state == 'pending_approval'"
                  decoration-danger="approval_state == 'rejected'">
                <field name="test_case_id"/>
                <field name="test_case_title"/>
                <field name="project_id"/>
                <field name="module_id"/>
                <field name="approval_state" widget="badge"
                       decoration-warning="approval_state == 'pending_approval'"
                       decoration-success="approval_state == 'approved'"
                       decoration-danger="approval_state == 'rejected'"/>
                <field name="status"/>
                <field name="severity"/>
                <field name="test_type"/>
                <field name="environment"/>
                <field name="executed_date"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="qa_testapp_view_test_case_form" model="ir.ui.view">
        <field name="name">qa_testapp.test_case.form</field>
        <field name="model">qa_testapp.test_case</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_creator_edit" type="object" string="Edit"
                            class="btn-primary"
                            invisible="not is_creator or creator_unlocked"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-success"
                            invisible="approval_state != 'pending_approval' or not is_current_user_approver"/>
                    <button name="action_reject_open_wizard" type="object" string="Reject"
                            class="btn-danger"
                            invisible="approval_state != 'pending_approval' or not is_current_user_approver"/>
                    <field name="approval_state" widget="statusbar" statusbar_visible="pending_approval,approved"/>
                    <field name="is_current_user_approver" invisible="1"/>
                    <field name="is_creator" invisible="1"/>
                    <field name="creator_unlocked" invisible="1"/>
                </header>
                <!-- Only the creator can edit (after clicking Edit). Everyone
                     else - including the PM - is read-only, in every state.
                     The 'id and' guard keeps a brand-new record editable. -->
                <!-- Definition fields are creator-only (read-only unless the
                     creator clicked Edit; per-field, since <sheet readonly>
                     does not cascade). Execution fields stay editable after
                     approval so the assignee/executor can record the result. -->
                <sheet>
                    <div class="alert alert-warning" role="alert"
                         invisible="approval_state != 'pending_approval'">
                        Pending approval from <field name="approver_id" readonly="1" nolabel="1" class="oe_inline"/>.
                        Execution is locked until approval.
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="approval_state != 'rejected'">
                        Rejected: <field name="rejection_reason" readonly="1" nolabel="1" class="oe_inline"/>
                    </div>
                    <group>
                        <group>
                            <field name="test_case_id" readonly="1"/>
                            <field name="test_case_title" readonly="id and not (is_creator and creator_unlocked)"/>
                            <field name="project_id" readonly="id and not (is_creator and creator_unlocked)"/>
                            <field name="approver_id" readonly="1"/>
                            <field name="available_module_ids" invisible="1"/>
                            <field name="module_id" readonly="id and not (is_creator and creator_unlocked)"/>
                        </group>
                        <group>
                            <field name="status" readonly="approval_state != 'approved'"/>
                            <field name="severity" readonly="id and not (is_creator and creator_unlocked)"/>
                            <field name="test_type" readonly="id and not (is_creator and creator_unlocked)"/>
                            <field name="environment" readonly="id and not (is_creator and creator_unlocked)"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Test Details">
                            <field name="test_objective" readonly="id and not (is_creator and creator_unlocked)"/>
                            <field name="pre_conditions" readonly="id and not (is_creator and creator_unlocked)"/>
                        </page>
                        <page string="Test Data &amp; Steps">
                            <group>
                                <field name="test_data" readonly="id and not (is_creator and creator_unlocked)"/>
                                <field name="test_steps" readonly="id and not (is_creator and creator_unlocked)"/>
                            </group>
                        </page>
                        <page string="Results">
                            <group>
                                <field name="expected_result" readonly="id and not (is_creator and creator_unlocked)"/>
                                <field name="actual_result" readonly="approval_state != 'approved'"/>
                            </group>
                        </page>
                        <page string="Execution">
                            <group>
                                <field name="executed_date" readonly="approval_state != 'approved'"/>
                                <field name="executed_by" readonly="approval_state != 'approved'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="qa_testapp_view_test_case_search" model="ir.ui.view">
        <field name="name">qa_testapp.test_case.search</field>
        <field name="model">qa_testapp.test_case</field>
        <field name="arch" type="xml">
            <search string="Search Test Cases">
                <field name="test_case_id"/>
                <field name="test_case_title"/>
                <field name="project_id"/>
                <field name="module_id"/>
                <separator/>
                <filter string="Pending Approval" name="filter_pending_approval"
                        domain="[('approval_state', '=', 'pending_approval')]"/>
                <filter string="Awaiting My Approval" name="filter_awaiting_my_approval"
                        domain="[('approval_state', '=', 'pending_approval'), ('approver_id', '=', uid)]"/>
                <filter string="Approved" name="filter_approved"
                        domain="[('approval_state', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected"
                        domain="[('approval_state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_by_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="group_by_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Approval State" name="group_by_approval_state"
                            context="{'group_by': 'approval_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="qa_testapp_action_test_case" model="ir.actions.act_window">
        <field name="name">Test Cases</field>
        <field name="res_model">qa_testapp.test_case</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="qa_testapp_view_test_case_search"/>
    </record>
</odoo>
