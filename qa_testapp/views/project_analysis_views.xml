<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                 PROJECT-WISE BUG ANALYSIS                   -->
    <!--       Uses model qa_testapp.bug.analysis                    -->
    <!-- ============================================================ -->
    <record id="view_pms_bug_analysis_pivot" model="ir.ui.view">
        <field name="name">qa_testapp.bug.analysis.pivot</field>
        <field name="model">qa_testapp.bug.analysis</field>
        <field name="arch" type="xml">
            <pivot string="Project-wise Analysis" sample="1">
                <field name="project_id" type="row"/>
                <field name="status" type="col"/>
                <field name="bug_count" type="measure"/>
                <field name="fixed_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_pms_bug_analysis_graph" model="ir.ui.view">
        <field name="name">qa_testapp.bug.analysis.graph</field>
        <field name="model">qa_testapp.bug.analysis</field>
        <field name="arch" type="xml">
            <graph string="Project-wise Analysis" type="bar" stacked="1" sample="1">
                <field name="project_id" type="row"/>
                <field name="status" type="col"/>
            </graph>
        </field>
    </record>

    <record id="view_pms_bug_analysis_search" model="ir.ui.view">
        <field name="name">qa_testapp.bug.analysis.search</field>
        <field name="model">qa_testapp.bug.analysis</field>
        <field name="arch" type="xml">
            <search string="Project-wise Analysis">
                <field name="bug_id"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="module_id"/>
                <field name="reporter_id"/>
                <field name="assignee_id"/>
                <field name="test_case_id"/>

                <!-- Status filters -->
                <filter name="filter_open" string="Open"
                        domain="[('status', '=', 'open')]"/>
                <filter name="filter_in_progress" string="In Progress"
                        domain="[('status', '=', 'in_progress')]"/>
                <filter name="filter_fixed" string="Fixed"
                        domain="[('status', '=', 'fixed')]"/>
                <filter name="filter_closed" string="Closed"
                        domain="[('status', '=', 'closed')]"/>
                <filter name="filter_reopened" string="Re-Opened"
                        domain="[('status', '=', 'reopened')]"/>
                <separator/>

                <!-- Severity filters -->
                <filter name="filter_severity_blocker" string="Blocker"
                        domain="[('severity', '=', 'blocker')]"/>
                <filter name="filter_severity_critical" string="Critical"
                        domain="[('severity', '=', 'critical')]"/>
                <filter name="filter_severity_major" string="Major"
                        domain="[('severity', '=', 'major')]"/>
                <separator/>

                <!-- Priority filters -->
                <filter name="filter_priority_p1" string="P1 - Urgent"
                        domain="[('priority', '=', 'p1')]"/>
                <filter name="filter_priority_p2" string="P2 - High"
                        domain="[('priority', '=', 'p2')]"/>
                <separator/>

                <!-- Source filters -->
                <filter name="filter_client" string="Client Reported"
                        domain="[('is_client', '=', True)]"/>
                <filter name="filter_internal" string="Internal Reported"
                        domain="[('is_internal', '=', True)]"/>
                <filter name="filter_reopened_any" string="Has Been Re-Opened"
                        domain="[('is_reopened', '=', True)]"/>
                <separator/>

                <!-- Date range filters -->
                <filter name="filter_reported_today" string="Reported Today"
                        domain="[('reported_date', '&gt;=', (context_today()).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="filter_reported_this_week" string="Reported This Week"
                        domain="[('reported_date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="filter_reported_this_month" string="Reported This Month"
                        domain="[('reported_date', '&gt;=', time.strftime('%%Y-%%m-01'))]"/>
                <filter name="filter_reported_this_year" string="Reported This Year"
                        domain="[('reported_date', '&gt;=', time.strftime('%%Y-01-01'))]"/>
                <separator/>

                <!-- Group by -->
                <filter name="groupby_project" string="Project"
                        context="{'group_by': 'project_id'}"/>
                <filter name="groupby_module" string="Module"
                        context="{'group_by': 'module_id'}"/>
                <filter name="groupby_assignee" string="Assignee"
                        context="{'group_by': 'assignee_id'}"/>
                <filter name="groupby_reporter" string="Reporter"
                        context="{'group_by': 'reporter_id'}"/>
                <filter name="groupby_status" string="Status"
                        context="{'group_by': 'status'}"/>
                <filter name="groupby_severity" string="Severity"
                        context="{'group_by': 'severity'}"/>
                <filter name="groupby_priority" string="Priority"
                        context="{'group_by': 'priority'}"/>
                <filter name="groupby_environment" string="Environment"
                        context="{'group_by': 'environment'}"/>
                <filter name="groupby_company" string="Company"
                        context="{'group_by': 'company_id'}"/>
                <filter name="groupby_reported_month" string="Reported Month"
                        context="{'group_by': 'reported_date:month'}"/>
                <filter name="groupby_reported_week" string="Reported Week"
                        context="{'group_by': 'reported_date:week'}"/>
            </search>
        </field>
    </record>

    <record id="view_pms_bug_analysis_list" model="ir.ui.view">
        <field name="name">qa_testapp.bug.analysis.list</field>
        <field name="model">qa_testapp.bug.analysis</field>
        <field name="arch" type="xml">
            <list string="Project-wise Analysis" create="0" edit="0" delete="0">
                <field name="bug_id"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="module_id"/>
                <field name="assignee_id"/>
                <field name="reporter_id"/>
                <field name="severity"/>
                <field name="priority"/>
                <field name="status"/>
                <field name="environment"/>
                <field name="reopen_count"/>
                <field name="reported_date"/>
            </list>
        </field>
    </record>

    <record id="action_pms_bug_analysis" model="ir.actions.act_window">
        <field name="name">Project-wise Analysis</field>
        <field name="res_model">qa_testapp.bug.analysis</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_pms_bug_analysis_search"/>
        <field name="context">{'search_default_groupby_project': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No bug data to analyse yet.
            </p>
            <p>
                Log bugs against projects to track fixed/open counts and
                current status per project.
            </p>
        </field>
    </record>

    <record id="act_pms_bug_analysis_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_pms_bug_analysis_pivot"/>
        <field name="act_window_id" ref="action_pms_bug_analysis"/>
    </record>

    <record id="act_pms_bug_analysis_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="20"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_pms_bug_analysis_graph"/>
        <field name="act_window_id" ref="action_pms_bug_analysis"/>
    </record>

    <record id="act_pms_bug_analysis_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="30"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_pms_bug_analysis_list"/>
        <field name="act_window_id" ref="action_pms_bug_analysis"/>
    </record>

</odoo>
