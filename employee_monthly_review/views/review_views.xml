<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="review_tree" model="ir.ui.view">
    <field name="name">review.tree</field>
    <field name="model">review</field>
    <field name="arch" type="xml">
      <list>
        <field name="review_month"/>
        <field name="employee_id"/>
        <field name="role"/>
        <field name="reviewer_id"/>
      </list>
    </field>
  </record>

  <record id="review_form" model="ir.ui.view">
    <field name="name">review.form</field>
    <field name="model">review</field>
    <field name="arch" type="xml">
      <form string="Monthly Review">
        <sheet>
          <div class="oe_title">
            <h1><field name="name" readonly="1"/></h1>
          </div>

          <group>
            <group>
              <field name="employee_id"/>
              <field name="review_month"/>
            </group>
            <group>
              <field name="role"/>
              <field name="reviewer_id"/>
            </group>
          </group>

          <notebook>
           <page string="Ratings">

    <!-- ================= COMMON ================= -->
    <group string="Common Parameters (All Roles)" >

        <label for="communication_clarity_rating" string="Communication Clarity"/>
        <div >
            <field name="communication_clarity_rating" class="oe_inline"/>
            <field name="communication_clarity_comment" class="oe_inline"/>
        </div>

        <label for="work_quality_rating" string="Work Quality"/>
        <div>
            <field name="work_quality_rating" class="oe_inline"/>
            <field name="work_quality_comment" class="oe_inline"/>
        </div>

        <label for="accountability_ownership_rating" string="Accountability / Ownership"/>
        <div>
            <field name="accountability_ownership_rating" class="oe_inline"/>
            <field name="accountability_ownership_comment" class="oe_inline"/>
        </div>

        <label for="process_adherence_rating" string="Process Adherence"/>
        <div>
            <field name="process_adherence_rating" class="oe_inline"/>
            <field name="process_adherence_comment" class="oe_inline"/>
        </div>

        <label for="deadline_discipline_rating" string="Deadline Discipline"/>
        <div>
            <field name="deadline_discipline_rating" class="oe_inline"/>
            <field name="deadline_discipline_comment" class="oe_inline"/>
        </div>

        <label for="learning_improvement_rating" string="Learning &amp; Improvement Attitude"/>
        <div>
            <field name="learning_improvement_rating" class="oe_inline"/>
            <field name="learning_improvement_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= SALES ================= -->
    <group string="Sales Parameters" invisible="role != 'sales'">

        <label for="prospecting_pipeline_discipline_rating" string="Prospecting &amp; Pipeline Discipline"/>
        <div>
            <field name="prospecting_pipeline_discipline_rating" class="oe_inline"/>
            <field name="prospecting_pipeline_discipline_comment" class="oe_inline"/>
        </div>

        <label for="objection_handling_negotiation_rating" string="Objection Handling &amp; Negotiation"/>
        <div>
            <field name="objection_handling_negotiation_rating" class="oe_inline"/>
            <field name="objection_handling_negotiation_comment" class="oe_inline"/>
        </div>

        <label for="follow_up_deal_progression_rating" string="Follow-Up &amp; Deal Progression"/>
        <div>
            <field name="follow_up_deal_progression_rating" class="oe_inline"/>
            <field name="follow_up_deal_progression_comment" class="oe_inline"/>
        </div>

        <label for="discovery_questioning_quality_rating" string="Discovery &amp; Questioning Quality"/>
        <div>
            <field name="discovery_questioning_quality_rating" class="oe_inline"/>
            <field name="discovery_questioning_quality_comment" class="oe_inline"/>
        </div>

        <label for="forecast_accuracy_revenue_ownership_rating" string="Forecast Accuracy &amp; Revenue Ownership"/>
        <div>
            <field name="forecast_accuracy_revenue_ownership_rating" class="oe_inline"/>
            <field name="forecast_accuracy_revenue_ownership_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= MARKETING ================= -->
    <group string="Marketing Parameters" invisible="role != 'marketing'" >

        <label for="campaign_planning_execution_rating" string="Campaign Planning &amp; Execution"/>
        <div>
            <field name="campaign_planning_execution_rating" class="oe_inline"/>
            <field name="campaign_planning_execution_comment" class="oe_inline"/>
        </div>

        <label for="lead_quality_contribution_rating" string="Lead Quality Contribution"/>
        <div>
            <field name="lead_quality_contribution_rating" class="oe_inline"/>
            <field name="lead_quality_contribution_comment" class="oe_inline"/>
        </div>

        <label for="performance_tracking_reporting_rating" string="Performance Tracking &amp; Reporting"/>
        <div>
            <field name="performance_tracking_reporting_rating" class="oe_inline"/>
            <field name="performance_tracking_reporting_comment" class="oe_inline"/>
        </div>

        <label for="tool_proficiency_ads_automation_crm_rating" string="Tool Proficiency (Ads/Automation/CRM)"/>
        <div>
            <field name="tool_proficiency_ads_automation_crm_rating" class="oe_inline"/>
            <field name="tool_proficiency_ads_automation_crm_comment" class="oe_inline"/>
        </div>

        <label for="creativity_experimentation_rating" string="Creativity &amp; Experimentation"/>
        <div>
            <field name="creativity_experimentation_rating" class="oe_inline"/>
            <field name="creativity_experimentation_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= DEVELOPER ================= -->
    <group string="Developer Parameters" invisible="role != 'developer'">

        <label for="technical_competency_rating" string="Technical Competency"/>
        <div>
            <field name="technical_competency_rating" class="oe_inline"/>
            <field name="technical_competency_comment" class="oe_inline"/>
        </div>

        <label for="code_quality_standards_rating" string="Code Quality &amp; Standards"/>
        <div>
            <field name="code_quality_standards_rating" class="oe_inline"/>
            <field name="code_quality_standards_comment" class="oe_inline"/>
        </div>

        <label for="debugging_root_cause_rating" string="Debugging / Root Cause Ability"/>
        <div>
            <field name="debugging_root_cause_rating" class="oe_inline"/>
            <field name="debugging_root_cause_comment" class="oe_inline"/>
        </div>

        <label for="requirement_understanding_accuracy_rating" string="Requirement Understanding Accuracy"/>
        <div>
            <field name="requirement_understanding_accuracy_rating" class="oe_inline"/>
            <field name="requirement_understanding_accuracy_comment" class="oe_inline"/>
        </div>

        <label for="estimation_accuracy_reliability_rating" string="Estimation Accuracy &amp; Reliability"/>
        <div>
            <field name="estimation_accuracy_reliability_rating" class="oe_inline"/>
            <field name="estimation_accuracy_reliability_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= TEAM LEAD ================= -->
    <group string="Team Lead Parameters" invisible="role != 'team_lead'">

        <label for="task_planning_allocation_rating" string="Task Planning &amp; Allocation"/>
        <div>
            <field name="task_planning_allocation_rating" class="oe_inline"/>
            <field name="task_planning_allocation_comment" class="oe_inline"/>
        </div>

        <label for="delivery_predictability_rating" string="Delivery Predictability"/>
        <div>
            <field name="delivery_predictability_rating" class="oe_inline"/>
            <field name="delivery_predictability_comment" class="oe_inline"/>
        </div>

        <label for="mentoring_technical_guidance_rating" string="Mentoring &amp; Technical Guidance"/>
        <div>
            <field name="mentoring_technical_guidance_rating" class="oe_inline"/>
            <field name="mentoring_technical_guidance_comment" class="oe_inline"/>
        </div>

        <label for="risk_identification_escalation_rating" string="Risk Identification &amp; Escalation"/>
        <div>
            <field name="risk_identification_escalation_rating" class="oe_inline"/>
            <field name="risk_identification_escalation_comment" class="oe_inline"/>
        </div>

        <label for="stakeholder_client_communication_rating" string="Stakeholder / Client Communication"/>
        <div>
            <field name="stakeholder_client_communication_rating" class="oe_inline"/>
            <field name="stakeholder_client_communication_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= PROJECT MANAGER ================= -->
    <group string="Project Manager Parameters" invisible="role != 'project_manager'">

        <label for="project_planning_timeline_control_rating" string="Project Planning &amp; Timeline Control"/>
        <div>
            <field name="project_planning_timeline_control_rating" class="oe_inline"/>
            <field name="project_planning_timeline_control_comment" class="oe_inline"/>
        </div>

        <label for="scope_change_management_rating" string="Scope &amp; Change Management"/>
        <div>
            <field name="scope_change_management_rating" class="oe_inline"/>
            <field name="scope_change_management_comment" class="oe_inline"/>
        </div>

        <label for="risk_dependency_management_rating" string="Risk &amp; Dependency Management"/>
        <div>
            <field name="risk_dependency_management_rating" class="oe_inline"/>
            <field name="risk_dependency_management_comment" class="oe_inline"/>
        </div>

        <label for="stakeholder_communication_rating" string="Stakeholder Communication"/>
        <div>
            <field name="stakeholder_communication_rating" class="oe_inline"/>
            <field name="stakeholder_communication_comment" class="oe_inline"/>
        </div>

        <label for="status_reporting_accuracy_rating" string="Status Reporting Accuracy"/>
        <div>
            <field name="status_reporting_accuracy_rating" class="oe_inline"/>
            <field name="status_reporting_accuracy_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= TESTER ================= -->
    <group string="Tester / QA Parameters" invisible="role != 'tester'">

        <label for="test_case_design_quality_rating" string="Test Case Design Quality"/>
        <div>
            <field name="test_case_design_quality_rating" class="oe_inline"/>
            <field name="test_case_design_quality_comment" class="oe_inline"/>
        </div>

        <label for="bug_reporting_clarity_rating" string="Bug Reporting Clarity"/>
        <div>
            <field name="bug_reporting_clarity_rating" class="oe_inline"/>
            <field name="bug_reporting_clarity_comment" class="oe_inline"/>
        </div>

        <label for="coverage_edge_case_thinking_rating" string="Coverage &amp; Edge Case Thinking"/>
        <div>
            <field name="coverage_edge_case_thinking_rating" class="oe_inline"/>
            <field name="coverage_edge_case_thinking_comment" class="oe_inline"/>
        </div>

        <label for="regression_discipline_rating" string="Regression Discipline"/>
        <div>
            <field name="regression_discipline_rating" class="oe_inline"/>
            <field name="regression_discipline_comment" class="oe_inline"/>
        </div>

        <label for="quality_ownership_rating" string="Quality Ownership"/>
        <div>
            <field name="quality_ownership_rating" class="oe_inline"/>
            <field name="quality_ownership_comment" class="oe_inline"/>
        </div>

    </group>

    <!-- ================= HR ================= -->
    <group string="HR Parameters" invisible="role != 'hr'">

        <label for="hiring_pipeline_management_rating" string="Hiring Pipeline Management"/>
        <div>
            <field name="hiring_pipeline_management_rating" class="oe_inline"/>
            <field name="hiring_pipeline_management_comment" class="oe_inline"/>
        </div>

        <label for="policy_compliance_documentation_rating" string="Policy Compliance &amp; Documentation"/>
        <div>
            <field name="policy_compliance_documentation_rating" class="oe_inline"/>
            <field name="policy_compliance_documentation_comment" class="oe_inline"/>
        </div>

        <label for="employee_issue_handling_rating" string="Employee Issue Handling"/>
        <div>
            <field name="employee_issue_handling_rating" class="oe_inline"/>
            <field name="employee_issue_handling_comment" class="oe_inline"/>
        </div>

        <label for="process_improvement_initiative_rating" string="Process Improvement Initiative"/>
        <div>
            <field name="process_improvement_initiative_rating" class="oe_inline"/>
            <field name="process_improvement_initiative_comment" class="oe_inline"/>
        </div>

        <label for="confidentiality_professionalism_rating" string="Confidentiality &amp; Professionalism"/>
        <div>
            <field name="confidentiality_professionalism_rating" class="oe_inline"/>
            <field name="confidentiality_professionalism_comment" class="oe_inline"/>
        </div>

    </group>

</page>

            <page string="Strengths &amp; Goals">
              <group colspan="2">
                <field name="strengths_top3" placeholder="1) ...  2) ...  3) ..."/>
                <field name="improvements_top3" placeholder="1) ...  2) ...  3) ..."/>
                <field name="goals_next_month" placeholder="1) ...  2) ...  3) ..."/>
              </group>
            </page>

          </notebook>
        </sheet>
      </form>
    </field>
  </record>






















    <!-- ACTION -->
    <record id="action_employee_monthly_review" model="ir.actions.act_window">
        <field name="name">Monthly Reviews</field>
        <field name="res_model">review</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS (Top-level App) -->
    <menuitem id="menu_employee_monthly_review_root" name="Performance Reviews"
              sequence="10" web_icon="employee_monthly_review,static/description/performance_review.png"/>

    <menuitem id="menu_employee_monthly_review" name="Monthly Reviews"
              parent="menu_employee_monthly_review_root"
              action="action_employee_monthly_review" sequence="10"/>
</odoo>
