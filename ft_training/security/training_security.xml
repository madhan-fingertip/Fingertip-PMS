<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- App access-rights category -->
        <record id="module_category_training" model="ir.module.category">
            <field name="name">Training</field>
            <field name="sequence">30</field>
        </record>

        <!-- Trainee: creates Today's Learning, reads the curriculum -->
        <record id="group_training_trainee" model="res.groups">
            <field name="name">Trainee</field>
            <field name="category_id" ref="module_category_training"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Trainees: create their own Today's Learning entries and read Learning Topics.</field>
        </record>

        <!-- Manager / Admin: maintains Learning Topics, sees all entries -->
        <record id="group_training_manager" model="res.groups">
            <field name="name">Training Manager / Admin</field>
            <field name="category_id" ref="module_category_training"/>
            <field name="implied_ids" eval="[(4, ref('group_training_trainee'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="comment">Admins: create/manage Learning Topics and view every trainee's Today's Learning.</field>
        </record>

        <!-- Today's Learning: a Trainee sees only their own entries -->
        <record id="rule_today_learning_own" model="ir.rule">
            <field name="name">Today's Learning: own entries (Trainee)</field>
            <field name="model_id" ref="model_ft_today_learning"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_training_trainee'))]"/>
        </record>

        <!-- Today's Learning: a Manager sees all entries (for evaluation) -->
        <record id="rule_today_learning_manager_all" model="ir.rule">
            <field name="name">Today's Learning: all entries (Manager)</field>
            <field name="model_id" ref="model_ft_today_learning"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_training_manager'))]"/>
        </record>

    </data>
</odoo>
